# Directory the agent is allowed to read/write. All file tool calls are sandboxed to this root.
AGENT_WORKDIR=../workspace

# Ollama server
OLLAMA_HOST=http://localhost:11434
MODEL_NAME=qwen3:8b

# CORS origin for the React dev server
FRONTEND_ORIGIN=http://localhost:5173

# MySQL (XAMPP defaults) - stores chat sessions. If unreachable, sessions are memory-only.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=coding_agent
